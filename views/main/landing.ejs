<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>College Buzz</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
        crossorigin="anonymous"
        referrerpolicy="no-referrer">

    <link rel="stylesheet" href="/landing.css">
</head>

<body>

    <!-- ========================= NAVBAR ========================= -->

    <header>

        <nav class="navbar">

            <!-- Event Slider -->
            <div class="events-container">

                <button class="arrow left">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>

                <div class="events" id="events">

                    <div class="event">🎉 Upcoming Events</div>
                    <div class="event">💻 BuildSprint Hackathon</div>
                    <div class="event">🎤 Tech Seminar</div>
                    <div class="event">🤖 AI Workshop</div>
                    <div class="event">🏆 Coding Contest</div>

                </div>

                <button class="arrow right">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>

            </div>

            <!-- Right Side -->
            <div class="nav-right">

                <a href="/auth/login" class="login-btn">
                    Login
                </a>

            </div>

        </nav>

    </header>

    <!-- ========================= HERO ========================= -->

    <main class="container">

        <section class="content">

            <section class="hero">

                <div class="main-project-logo">
                    <img src="campus-buzz2.png">
                </div>

                <p>
                    College Buzz is a unified platform that connects students,
                    clubs, committees and administration in one place.
                     <!-- Stay
                    updated with campus events, announcements, complaints,
                    discussions and official notices—all from a single portal. -->
                </p>

                <div class="hero-buttons">

                    <a href="/auth/login" class="primary-btn">
                        Get Started
                    </a>

                    <a href="#features" class="secondary-btn">
                        Explore Features
                    </a>

                </div>

            </section>

            <!-- ========================= FEATURES ========================= -->

            <section class="features" id="features">

                <div class="feature-card">

                    <i class="fa-solid fa-calendar-check"></i>

                    <h3>Campus Events</h3>

                    <p>
                        Discover hackathons, workshops, seminars,
                        competitions and every important event happening
                        around your campus.
                    </p>

                </div>

                <div class="feature-card">

                    <i class="fa-solid fa-comments"></i>

                    <h3>Campus Buzz</h3>

                    <p>
                        Share updates, connect with students,
                        participate in discussions and stay
                        informed about campus life.
                    </p>

                </div>

                <div class="feature-card">

                    <i class="fa-solid fa-circle-exclamation"></i>

                    <h3>Complaint Portal</h3>

                    <p>
                        Raise complaints digitally,
                        monitor their progress,
                        and receive transparent updates
                        from the administration.
                    </p>

                </div>

                <div class="feature-card">

                    <i class="fa-solid fa-users"></i>

                    <h3>Club & Committee Feed</h3>

                    <p>
                        Access official announcements,
                        forms, notices and updates
                        from clubs and committees.
                    </p>

                </div>

            </section>

            <!-- ========================= CTA ========================= -->

            <section class="cta">

                <h2>
                    Everything About Your Campus, In One Place.
                </h2>

                <p>
                    Join College Buzz today and never miss an announcement,
                    event, opportunity or update from your college.
                </p>

                <a href="/auth/login" class="primary-btn">
                    Login Now
                </a>

            </section>

        </section>

    </main>

    <!-- ========================= FOOTER ========================= -->

    <footer class="footer">

        <div class="footer-content">

            <div class="footer-box">

                <h3>College Buzz</h3>

                <p>
                    Bringing students, clubs,
                    committees and administration
                    together through one unified
                    digital platform.
                </p>

            </div>

            <div class="footer-box">

                <h3>Quick Links</h3>

                <a href="#">Home</a>
                <a href="#">Events</a>
                <a href="#">Campus Buzz</a>
                <a href="#">Complaints</a>

            </div>

            <div class="footer-box">

                <h3>Connect With Us</h3>

                <a href="#">
                    <i class="fa-brands fa-facebook"></i>
                    Facebook
                </a>

                <a href="#">
                    <i class="fa-brands fa-instagram"></i>
                    Instagram
                </a>

                <a href="#">
                    <i class="fa-brands fa-linkedin"></i>
                    LinkedIn
                </a>

                <a href="#">
                    <i class="fa-brands fa-youtube"></i>
                    YouTube
                </a>

            </div>

        </div>

        <hr>

        <p class="copyright">
            © 2026 College Buzz • NIT Raipur • All Rights Reserved
        </p>

    </footer>

    <script src="/landing.js"></script>

</body>

</html>